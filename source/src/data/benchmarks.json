  "scaling": {
    "description": "Yeti scales linearly. Add nodes, get proportional throughput. Reads and writes both scale with cluster size.",
    "replication": {
      "description": "With RF=3, every write is replicated to 2 additional nodes for fault tolerance. This caps write throughput at floor(N/3) × single-node. Reads always scale linearly.",
      "rf": 3,
      "formula": {
        "reads": "N × single_node_reads",
        "writes_no_replication": "N × single_node_writes",
        "writes_rf3": "floor(N / RF) × single_node_writes"
      }
    },
    "measured": [
      { "tier": "8gb",  "nodes": 1, "read_rps": 25076,  "write_rps": 13678 },
      { "tier": "8gb",  "nodes": 3, "read_rps": 73281,  "write_rps": 46818,  "read_ratio": 2.92, "write_ratio": 3.42 },
